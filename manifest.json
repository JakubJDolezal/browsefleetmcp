{
  "manifest_version": "0.3",
  "name": "browsefleetmcp",
  "display_name": "BrowseFleetMCP",
  "version": "0.1.3",
  "description": "Parallel browser automation MCP server for Chrome with isolated sessions and screenshots.",
  "author": {
    "name": "Jakub Dolezal",
    "url": "https://github.com/JakubJDolezal/browsefleetmcp"
  },
  "homepage": "https://github.com/JakubJDolezal/browsefleetmcp",
  "documentation": "https://github.com/JakubJDolezal/browsefleetmcp#readme",
  "support": "https://github.com/JakubJDolezal/browsefleetmcp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/JakubJDolezal/browsefleetmcp.git"
  },
  "icon": ".github/images/browsefleetmcp-mark.png",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "browser",
    "chrome",
    "automation",
    "parallel"
  ],
  "compatibility": {
    "platforms": [
      "darwin",
      "win32",
      "linux"
    ]
  },
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/index.js"
      ]
    }
  }
}
