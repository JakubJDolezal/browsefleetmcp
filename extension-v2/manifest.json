{
  "manifest_version": 3,
  "name": "BrowseFleetMCP",
  "version": "0.0.2",
  "minimum_chrome_version": "116",
  "description": "Parallel browser control with isolated windows, real screenshots, and MCP support.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BrowseFleetMCP",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },
  "permissions": [
    "desktopCapture",
    "debugger",
    "offscreen",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
